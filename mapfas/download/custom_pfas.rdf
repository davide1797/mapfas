    <!-- http://purl.obolibrary.org/obo/CHEBI_172406 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CHEBI_172406">
        <rdfs:subClassOf rdf:resource="https://w3id.org/OntoPFAS#Pfas"/>
        <owl:disjointWith rdf:resource="http://purl.obolibrary.org/obo/CHEBI_24531"/>
        <oboInOwl:hasDbXref>Wikipedia:Per-_and_polyfluoroalkyl_substances</oboInOwl:hasDbXref>
        <oboInOwl:hasExactSynonym>polyfluoroalkyl substances</oboInOwl:hasExactSynonym>
        <oboInOwl:hasOBONamespace>chebi_ontology</oboInOwl:hasOBONamespace>
        <oboInOwl:hasRelatedSynonym>PFAS</oboInOwl:hasRelatedSynonym>
        <oboInOwl:id>CHEBI:172406</oboInOwl:id>
        <oboInOwl:inSubset>http://purl.obolibrary.org/obo/chebi#3_STAR</oboInOwl:inSubset>
        <rdfs:comment>An organofluorine compound that has multiple fluorine atoms attached to an alkyl chain (but at least one of the carbon atoms in the chain is not fully fluorinated).</rdfs:comment>
        <rdfs:label>Polyfluoroalkyl</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/CHEBI_24431 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CHEBI_24431">
        <oboInOwl:hasExactSynonym>chemical entity</oboInOwl:hasExactSynonym>
        <oboInOwl:hasOBONamespace>chebi_ontology</oboInOwl:hasOBONamespace>
        <oboInOwl:id>CHEBI:24431</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/chebi#3_STAR"/>
        <rdfs:comment>A chemical entity is a physical entity of interest in chemistry including molecular entities, parts thereof, and chemical substances.</rdfs:comment>
        <rdfs:label>Chemical entity</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/CHEBI_24431"/>
        <owl:annotatedProperty rdf:resource="http://www.geneontology.org/formats/oboInOwl#hasExactSynonym"/>
        <owl:annotatedTarget>chemical entity</owl:annotatedTarget>
        <oboInOwl:hasDbXref>UniProt</oboInOwl:hasDbXref>
    </owl:Axiom>
    


    <!-- http://purl.obolibrary.org/obo/CHEBI_24531 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CHEBI_24531">
        <rdfs:subClassOf rdf:resource="https://w3id.org/OntoPFAS#Pfas"/>
        <oboInOwl:hasDbXref>Wikipedia:Per-_and_polyfluoroalkyl_substances</oboInOwl:hasDbXref>
        <oboInOwl:hasExactSynonym>perfluoroalkyl substances</oboInOwl:hasExactSynonym>
        <oboInOwl:hasOBONamespace>chebi_ontology</oboInOwl:hasOBONamespace>
        <oboInOwl:hasRelatedSynonym>PFAS</oboInOwl:hasRelatedSynonym>
        <oboInOwl:hasRelatedSynonym>perfluorinated alkylated substance</oboInOwl:hasRelatedSynonym>
        <oboInOwl:hasRelatedSynonym>perfluorinated alkylated substances</oboInOwl:hasRelatedSynonym>
        <oboInOwl:hasRelatedSynonym>perfluoroalkyl compound</oboInOwl:hasRelatedSynonym>
        <oboInOwl:hasRelatedSynonym>perfluoroalkyl compounds</oboInOwl:hasRelatedSynonym>
        <oboInOwl:id>CHEBI:172397</oboInOwl:id>
        <oboInOwl:inSubset>http://purl.obolibrary.org/obo/chebi#3_STAR</oboInOwl:inSubset>
        <rdfs:comment>A perfluorinated compound in which the carbon chain atoms are completely fluorinated.</rdfs:comment>
        <rdfs:label>Perfluoroalkyl</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/CHEBI_83814 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CHEBI_83814">
        <rdfs:subClassOf rdf:resource="https://w3id.org/OntoPFAS#PfasPrecursor"/>
        <oboInOwl:hasDbXref>wikipedia.en:Fluorotelomer</oboInOwl:hasDbXref>
        <oboInOwl:hasExactSynonym>Fluorotelomers</oboInOwl:hasExactSynonym>
        <oboInOwl:hasOBONamespace>chebi_ontology</oboInOwl:hasOBONamespace>
        <oboInOwl:hasRelatedSynonym>fluorotelomers</oboInOwl:hasRelatedSynonym>
        <oboInOwl:id>CHEBI:83814</oboInOwl:id>
        <oboInOwl:inSubset>http://purl.obolibrary.org/obo/3_STAR</oboInOwl:inSubset>
        <rdfs:label>Fluorotelomer</rdfs:label>
        <skos:definition>Any organofluorine compound that is a oligomer or telomer synthesised by telomerization (a chain transfer reaction to produce an oligomer of a limited size). They are generally used in fire-fighting foams, leather protectants, food packaging and stain resistants.</skos:definition>
        <skos:notation>CHEBI:83814</skos:notation>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/ENVO_01000408 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/ENVO_01000408">
        <rdfs:comment>Formerly, this class was an experimental class and a subclass of &quot;environmental feature&quot;. It is now aligned to BFO. The class was not obsoleted as the core semantics maintained their stability through its transition.</rdfs:comment>
        <rdfs:label>Environmental zone</rdfs:label>
        <skos:definition>A site which has its extent determined by the presence or influence of one or more components of an environmental system or the processes occurring therein.</skos:definition>
    </owl:Class>
    


