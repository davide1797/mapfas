    <!-- http://purl.obolibrary.org/obo/ExO_0000022 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/ExO_0000022">
        <oboInOwl:created_by>http://orcid.org/0000-0002-7463-6306</oboInOwl:created_by>
        <oboInOwl:creation_date>2021-10-20T17:44:37Z</oboInOwl:creation_date>
        <oboInOwl:hasOBONamespace>source</oboInOwl:hasOBONamespace>
